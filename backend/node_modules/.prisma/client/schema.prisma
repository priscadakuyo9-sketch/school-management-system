// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ---------------------------
// 1. UTILISATEURS & PERSONNEL
// ---------------------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("PARENT") // ADMIN, TEACHER, STAFF, PARENT, STUDENT
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?
}

// Enum Role removed for SQLite compatibility

model Parent {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Peut avoir plusieurs enfants
  students Student[]
}

model Teacher {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialty String?

  // Relations
  classes    Class[] // Classes dirigées
  courses    Course[] // Cours enseignés
  attendance Attendance[] // Validation d'absences
}

// ---------------------------
// 2. ÉLÈVES & INSCRIPTIONS
// ---------------------------

model Student {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  enrollmentId String   @unique // Matricule scolaire
  dateOfBirth  DateTime
  gender       String
  address      String?
  medicalInfo  String? // Allergies, etc.

  // Relation avec les parents
  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  grades       Grade[]
  attendances  Attendance[]
  behaviorLogs BehaviorLog[]
  payments     Payment[]

  createdAt DateTime @default(now())
}

// ---------------------------
// 3. ACADÉMIQUE
// ---------------------------

model Class {
  id       String @id @default(uuid())
  name     String // ex: 6ème A, 1ère S
  level    String // Primaire, Collège, etc.
  capacity Int

  teacherId String? // Professeur principal
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  students Student[]
  courses  Course[]
}

model Course {
  id          String  @id @default(uuid())
  name        String // Mathématiques, Histoire...
  description String?

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  grades   Grade[]
  schedule Schedule[]
}

model Schedule {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  dayOfWeek Int // 1 (Lundi) à 7 (Dimanche)
  startTime String // Ex: 08:00
  endTime   String // Ex: 10:00
  room      String? // Salle C12
}

model Grade {
  id       String  @id @default(uuid())
  score    Float
  maxScore Float   @default(20)
  term     String // Trimestre 1, Semestre 1...
  comments String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
}

model Attendance {
  id     String   @id @default(uuid())
  date   DateTime
  status String // PRESENT, ABSENT, LATE, EXCUSED
  notes  String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
}

// Enum AttendanceStatus removed

// ---------------------------
// 4. DISCIPLINE & COMPORTEMENT
// ---------------------------

model BehaviorLog {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  title       String
  description String
  type        String // POSITIVE, NEGATIVE, WARNING

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

// Enum BehaviorType removed

// ---------------------------
// 5. FINANCE (PAIEMENTS)
// ---------------------------

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  currency    String    @default("EUR")
  status      String    @default("PENDING")
  description String // Ex: Frais de scolarité Trimestre 1
  dueDate     DateTime
  paidDate    DateTime?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

// Enum PaymentStatus removed
